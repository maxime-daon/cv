---
import BaseLayout from "@layouts/BaseLayout.astro"
---

<BaseLayout title="Page introuvable" noindex>
  <section class="mx-auto flex max-w-6xl flex-col items-center justify-center px-4 py-20 text-center">
    <h1 class="text-6xl font-bold text-[var(--color-primary)]">404</h1>
    <p class="mt-4 text-xl text-gray-600">Cette page n'existe pas ou a été déplacée.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-[var(--radius)] bg-[var(--color-primary)] px-5 py-2.5 font-medium text-white transition-colors hover:opacity-90"
    >
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
