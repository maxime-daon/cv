---
import type { Project, ProjectCategory } from "../../types/index"
import Tag from "@components/ui/Tag.astro"

interface Props {
  project: Project
  featured?: boolean
}

const { project, featured = false } = Astro.props

type CategoryMeta = { bg: string; text: string; label: string }

const categoryColors: Record<ProjectCategory, CategoryMeta> = {
  webflow: { bg: "rgba(235,247,239,0.9)", text: "#2E8A4A", label: "Webflow" },
  seo:     { bg: "rgba(235,247,239,0.9)", text: "#2E8A4A", label: "SEO" },
  "google-ads": { bg: "rgba(255,247,237,0.9)", text: "#ea580c", label: "Google Ads" },
  dev:          { bg: "rgba(243,232,255,0.9)", text: "#7c3aed", label: "Dev" },
  "side-project": { bg: "rgba(240,239,235,0.9)", text: "#4a4a44", label: "Side project" },
}

const cat = categoryColors[project.category]
---

<article
  class:list={[
    "project-card group flex flex-col overflow-hidden rounded-lg border border-(--color-border) bg-(--color-surface) transition-all",
    featured && "md:flex-row",
  ]}
>
  {/* Image */}
  <div
    class:list={[
      "relative overflow-hidden bg-(--color-bg-secondary)",
      featured ? "aspect-video md:aspect-auto md:w-2/5" : "aspect-video",
    ]}
  >
    <img
      src={project.image}
      alt={project.title}
      class="h-full w-full object-cover transition-transform duration-400 [cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-[1.04]"
      loading="lazy"
      onerror={`this.src='https://placehold.co/800x450/F0EFEB/9C9C96?text=${encodeURIComponent(project.title)}'`}
    />
    {/* Gradient overlay */}
    <div
      class="pointer-events-none absolute inset-0"
      style="background: linear-gradient(to top, rgba(0,0,0,0.15), transparent);"
    ></div>
    {/* Category badge */}
    <span
      class="absolute left-3 top-3 rounded-full px-3 py-1 text-[11px] font-semibold uppercase leading-none tracking-[0.04em] backdrop-blur-sm"
      style={`background: ${cat.bg}; color: ${cat.text};`}
    >
      {cat.label}
    </span>
  </div>

  {/* Content */}
  <div class="flex flex-1 flex-col p-6">
    {/* Title + client + year */}
    <div class="mb-1 flex items-start justify-between gap-2">
      <h3 class="min-w-0 text-lg font-semibold text-(--color-text-primary)" style="font-family: var(--font-sans);">
        {/* EDIT: project title */}
        {project.title}
      </h3>
      <span class="shrink-0 text-sm text-(--color-text-muted)">{project.year}</span>
    </div>
    <p class="text-sm text-(--color-text-muted)">{project.client}</p>

    {/* Description */}
    <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-(--color-text-secondary)">
      {project.description}
    </p>

    {/* Tags */}
    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.tags.map((tag) => <Tag label={tag} />)}
    </div>

    {/* Results */}
    {project.results && (
      <div class="mt-3 inline-flex items-center gap-1.5 self-start rounded-sm bg-(--color-accent-light) px-2.5 py-1.5">
        <span class="text-sm font-semibold text-(--color-accent)">↑</span>
        <span class="text-sm font-semibold text-(--color-accent)">{project.results}</span>
      </div>
    )}

    {/* Link */}
    <div class="mt-auto pt-4">
      <a
        href={`/projets/${project.slug}`}
        class="inline-flex items-center gap-1 text-sm font-medium text-(--color-accent) transition-colors hover:text-(--color-accent-hover)"
      >
        Voir le projet
        <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</article>

<style>
  .project-card {
    transition: border-color 300ms cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow   300ms cubic-bezier(0.34, 1.56, 0.64, 1),
                transform    300ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .project-card:hover {
    border-color: var(--color-accent-muted);
    box-shadow: 0 8px 32px -8px rgba(61, 163, 93, 0.18);
    transform: translateY(-3px);
  }
</style>
