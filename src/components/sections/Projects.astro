---
import SectionTitle from "@components/ui/SectionTitle.astro"
import ProjectCard from "@components/ui/ProjectCard.astro"
import { projects } from "@config/projects"

const featured = projects.filter((p) => p.featured)
const rest = projects.filter((p) => !p.featured)

const categories = [
  { id: "all", label: "Tous" },
  { id: "webflow", label: "Webflow" },
  { id: "seo", label: "SEO" },
  { id: "google-ads", label: "Google Ads" },
  { id: "dev", label: "Dev" },
  { id: "side-project", label: "Side projects" },
]
---

<section id="projets" class="py-20 md:py-28">
  <div class="mx-auto max-w-(--container-max) px-6">
    <SectionTitle
      title="Réalisations"
      subtitle="Projets récents en Webflow, SEO, Google Ads et développement front-end."
    />

    {/* Filter pills */}
    <div class="mb-10 flex flex-wrap gap-2" id="project-filters">
      {categories.map((cat, i) => (
        <button
          type="button"
          data-filter={cat.id}
          class:list={[
            "filter-pill rounded-full border px-4 py-1.5 text-sm font-medium transition-colors",
            i === 0
              ? "border-(--color-accent) bg-(--color-accent) text-white"
              : "border-(--color-border) bg-transparent text-(--color-text-secondary) hover:border-(--color-border-strong) hover:text-(--color-text-primary)",
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    {/* Featured projects — full width */}
    <div class="mb-8 flex flex-col gap-6" id="featured-projects">
      {featured.map((project) => (
        <div data-category={project.category}>
          <ProjectCard project={project} featured={true} />
        </div>
      ))}
    </div>

    {/* Other projects — 2 cols grid */}
    <div class="grid gap-6 md:grid-cols-2" id="other-projects">
      {rest.map((project) => (
        <div data-category={project.category}>
          <ProjectCard project={project} />
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFilters() {
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]")
    const cards = document.querySelectorAll<HTMLElement>("[data-category]")

    const activeClasses = [
      "border-(--color-accent)",
      "bg-(--color-accent)",
      "text-white",
    ]
    const inactiveClasses = [
      "border-(--color-border)",
      "bg-transparent",
      "text-(--color-text-secondary)",
    ]

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter!

        buttons.forEach((b) => {
          const isActive = b.dataset.filter === filter
          activeClasses.forEach((c) => b.classList.toggle(c, isActive))
          inactiveClasses.forEach((c) => b.classList.toggle(c, !isActive))
        })

        cards.forEach((card) => {
          const match = filter === "all" || card.dataset.category === filter
          card.style.display = match ? "" : "none"
        })
      })
    })
  }

  initFilters()
  document.addEventListener("astro:after-swap", initFilters)
</script>
