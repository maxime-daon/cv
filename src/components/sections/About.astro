---
import SectionTitle from "@components/ui/SectionTitle.astro"
import Button from "@components/ui/Button.astro"
import Tag from "@components/ui/Tag.astro"
import { skills } from "@config/skills"
import { Image } from "astro:assets"
---

<section id="a-propos" class="py-20 md:py-28">
  <div class="mx-auto max-w-(--container-max) px-6">
    <SectionTitle title="À propos" />

    <div class="flex flex-col gap-12 md:flex-row md:gap-16">
      {/* Left — bio */}
      <div class="flex flex-col gap-6 md:w-1/2">
        {/* Avatar initials */}
        <div
          class="flex h-24 w-24 items-center justify-center rounded-full bg-(--color-accent-light) text-xl font-semibold text-(--color-accent)"
          aria-label="Maxime Daon"
        >
          <img
            src="/photo-linkedin.png"
            alt="Photo de Maxime Daon"
            class="h-full w-full rounded-full object-cover"
          />
        </div>

        {/* EDIT: bio content */}
        <p class="leading-relaxed text-(--color-text-secondary)">
          Développeur Webflow et Traffic Manager freelance avec 4 ans d'expérience, j'accompagne
          indépendants et PME dans leur présence digitale, du site à l'acquisition de trafic.
        </p>
        <p class="leading-relaxed text-(--color-text-secondary)">
          Master Digital Marketing (IAE Caen) + DUT MMI. J'ai travaillé en remote depuis l'étranger
          et je rentre en France mi-2026, disponible pour des missions freelance et ouvert aux
          opportunités en CDI marketing, growth ou développement front-end.
        </p>

        {/* EDIT: lien CV */}
        <div>
          <Button href="/CV_Maxime_Daon_marketing.pdf" variant="ghost" external={true}>
            Télécharger mon CV
          </Button>
        </div>
      </div>

      {/* Right — skills */}
      <div class="flex flex-col gap-8 md:w-1/2">
        {skills.map((group) => (
          <div>
            <h3 class="mb-3 text-sm font-semibold uppercase tracking-widest text-(--color-text-muted)">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((skill) => <Tag label={skill} />)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
