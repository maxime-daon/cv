---
/**
 * Layout pour les articles de blog.
 * Prêt à être branché sur Sanity ou toute autre source de contenu.
 */
import BaseLayout from "@layouts/BaseLayout.astro"
import Breadcrumb from "@components/Breadcrumb.astro"
import JsonLd from "@components/seo/JsonLd.astro"
import { buildArticle } from "@lib/schema"

interface Props {
  title: string
  description: string
  publishedAt: Date
  updatedAt?: Date
  ogImage?: string
}

const { title, description, publishedAt, updatedAt, ogImage } = Astro.props
const articleSchema = buildArticle({
  title,
  description,
  url: Astro.url.pathname,
  publishedAt,
  updatedAt,
  image: ogImage,
})
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <JsonLd schema={articleSchema} />
  <article class="mx-auto max-w-3xl px-4 py-12">
    <Breadcrumb items={[{ name: "Blog", href: "/blog" }, { name: title, href: Astro.url.pathname }]} />
    <header class="mb-8">
      <h1 class="text-3xl font-bold md:text-4xl">{title}</h1>
      <slot name="meta" />
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
